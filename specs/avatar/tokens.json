{
  "$schema": "../../_templates/component/tokens.schema.json",
  "component": "avatar",
  "source": "https://github.com/tishsingh399/clementine-ds",
  "version": "clementine-ds@HEAD",
  "verified": "2026-06-10",
  "fork_model": "3-tier cascade: component → semantic → primitive. Components never reference primitives directly.",
  "notes": [
    "All entries are tier=component, defined in packages/tokens/src/components/avatar.json.",
    "`references` is the semantic token bound; `primitive` is the resolved primitive after the second hop.",
    "Light-mode values shown; dark resolves through the same semantic names in semantic-dark.json."
  ],
  "tokens": [
    { "name": "avatar.bg",     "tier": "component", "role": "placeholder-fill", "path": "avatar.bg",     "references": "{surface.subtle}", "primitive": "{color.gray.1}", "light": "#f3f3f0", "status": "existing" },
    { "name": "avatar.fg",     "tier": "component", "role": "initials-color",   "path": "avatar.fg",     "references": "{text.secondary}", "primitive": "{color.gray.6}", "light": "#6b6b66", "status": "existing" },
    { "name": "avatar.border", "tier": "component", "role": "group-ring",       "path": "avatar.border", "references": "{border.default}", "primitive": "{color.gray.2}", "light": "#e5e5e0", "status": "existing" },
    { "name": "avatar.ring",   "tier": "component", "role": "focus-ring",       "path": "avatar.ring",   "references": "{focus.ring}",     "primitive": "literal",        "light": "#ff8040", "status": "existing" },
    { "name": "avatar.radius", "tier": "component", "role": "corner-radius",    "path": "avatar.radius", "references": "{radius.xl}",      "primitive": "99px",           "light": "99px",    "status": "existing" }
  ]
}
