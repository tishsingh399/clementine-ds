{
  "$schema": "../../_templates/component/tokens.schema.json",
  "component": "skeleton",
  "source": "https://github.com/tishsingh399/clementine-ds",
  "version": "clementine-ds@HEAD",
  "verified": "2026-06-10",
  "fork_model": "3-tier cascade: component → semantic → primitive. Components never reference primitives directly.",
  "notes": [
    "All entries are tier=component, defined in packages/tokens/src/components/skeleton.json.",
    "skeleton.duration binds the shimmer cycle to motion.duration-stream; honor prefers-reduced-motion."
  ],
  "tokens": [
    { "name": "skeleton.base",      "tier": "component", "role": "placeholder-fill", "path": "skeleton.base",      "references": "{surface.subtle}",        "primitive": "{color.gray.1}", "light": "#f3f3f0", "status": "existing" },
    { "name": "skeleton.highlight", "tier": "component", "role": "shimmer-highlight","path": "skeleton.highlight", "references": "{surface.default}",       "primitive": "{color.gray.0}", "light": "#fafaf8", "status": "existing" },
    { "name": "skeleton.duration",  "tier": "component", "role": "shimmer-cycle",    "path": "skeleton.duration",  "references": "{motion.duration-stream}","primitive": "1200ms",         "light": "1200ms",  "status": "existing" },
    { "name": "skeleton.radius",    "tier": "component", "role": "corner-radius",    "path": "skeleton.radius",    "references": "{radius.md}",             "primitive": "6px",            "light": "6px",     "status": "existing" }
  ]
}
