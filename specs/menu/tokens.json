{
  "$schema": "../../_templates/component/tokens.schema.json",
  "component": "menu",
  "source": "https://github.com/tishsingh399/clementine-ds",
  "version": "clementine-ds@HEAD",
  "verified": "2026-06-10",
  "fork_model": "3-tier cascade: component → semantic → primitive. Components never reference primitives directly.",
  "notes": [
    "All entries are tier=component, defined in packages/tokens/src/components/menu.json.",
    "`references` is the semantic token bound; `primitive` is the resolved primitive after the second hop.",
    "Light-mode values shown; dark resolves through the same semantic names in semantic-dark.json."
  ],
  "tokens": [
    { "name": "menu.bg",           "tier": "component", "role": "dropdown-fill",   "path": "menu.bg",           "references": "{surface.elevated}", "primitive": "{color.white}",  "light": "#ffffff", "status": "existing" },
    { "name": "menu.border",       "tier": "component", "role": "dropdown-border", "path": "menu.border",       "references": "{border.default}",   "primitive": "{color.gray.2}", "light": "#e5e5e0", "status": "existing" },
    { "name": "menu.shadow",       "tier": "component", "role": "elevation",       "path": "menu.shadow",       "references": "{shadow.lg}",        "primitive": "0 8px 24px rgba(0,0,0,0.16)", "light": "0 8px 24px rgba(0,0,0,0.16)", "status": "existing" },
    { "name": "menu.radius",       "tier": "component", "role": "corner-radius",   "path": "menu.radius",       "references": "{radius.md}",        "primitive": "6px",            "light": "6px",     "status": "existing" },
    { "name": "menu.item.fg",      "tier": "component", "role": "item-color",      "path": "menu.item.fg",      "references": "{text.primary}",     "primitive": "{color.gray.9}", "light": "#1a1a18", "status": "existing" },
    { "name": "menu.item.fg-danger","tier": "component","role": "destructive-color","path": "menu.item.fg-danger","references": "{feedback.error}",  "primitive": "{color.red.6}",  "light": "#dc2626", "status": "existing" },
    { "name": "menu.item.bg-hover","tier": "component", "role": "item-hover-fill",  "path": "menu.item.bg-hover","references": "{surface.subtle}",   "primitive": "{color.gray.1}", "light": "#f3f3f0", "status": "existing" },
    { "name": "menu.label",        "tier": "component", "role": "group-heading",   "path": "menu.label",        "references": "{text.secondary}",   "primitive": "{color.gray.6}", "light": "#6b6b66", "status": "existing" },
    { "name": "menu.divider",      "tier": "component", "role": "separator",       "path": "menu.divider",      "references": "{border.default}",   "primitive": "{color.gray.2}", "light": "#e5e5e0", "status": "existing" }
  ]
}
