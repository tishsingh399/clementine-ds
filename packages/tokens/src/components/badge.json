{
  "badge": {
    "bg": {
      "neutral":      { "$value": "{surface.subtle}",          "$type": "color" },
      "success":      { "$value": "{feedback.success-subtle}", "$type": "color" },
      "error":        { "$value": "{feedback.error-subtle}",   "$type": "color" },
      "warning":      { "$value": "{feedback.warning-subtle}", "$type": "color" },
      "risk-critical": { "$value": "{risk.critical-subtle}",   "$type": "color" },
      "risk-high":    { "$value": "{risk.high-subtle}",        "$type": "color" },
      "risk-medium":  { "$value": "{risk.medium-subtle}",      "$type": "color" },
      "risk-low":     { "$value": "{risk.low-subtle}",         "$type": "color" }
    },
    "fg": {
      "default":      { "$value": "{text.primary}",   "$type": "color" }
    },
    "radius":         { "$value": "{radius.sm}", "$type": "dimension" }
  }
}
