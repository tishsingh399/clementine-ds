# Copy this file to .env and fill in real values.
# .env is gitignored — your real keys never get committed.
#
# Usage:
#   cp .env.example .env
#   # edit .env, paste real values
#   node --env-file=.env scripts/upload-readme-docs.js

# ReadMe.io API key — for scripts/upload-readme-docs.js
# Get one at: https://dash.readme.com/project/<your-project>/api-key
# Format: rdme_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RDM_API_KEY=

# ReadMe.io version slug — defaults to v1.0 if unset.
# Find/create in: ReadMe.io → your project → top-left "Version" dropdown
RDM_VERSION=v1.0

# Chromatic project token — for visual regression (added later)
# Get one at: https://www.chromatic.com → your project → Manage → Project Token
# Format: chpt_xxxxxxxxxxxxxxxxxxxxxxx
CHROMATIC_PROJECT_TOKEN=

# Infisical service token — for fetching production secrets at CI time (optional)
# Format: st.xxxxxxxxxxxxxxxxxxxxxxxxxxx
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
